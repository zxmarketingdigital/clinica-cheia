CLINICA_NOME=
WHATSAPP_PROVIDER=uazapi          # uazapi | zapi | meta

# --- uazapi (provider recomendado / dedicado) ---
UAZAPI_URL=
UAZAPI_TOKEN=

# --- zapi (use quando a instância já roda na Z-API) ---
# ZAPI_INSTANCE=
# ZAPI_TOKEN=
# ZAPI_CLIENT_TOKEN=

SUPABASE_URL=
SUPABASE_SERVICE_KEY=
GEMINI_API_KEY=
GOOGLE_REVIEW_LINK=
# registre o webhook no provider como <WORKER_URL>/webhook?token=<WEBHOOK_SECRET>
WEBHOOK_SECRET=

# Gating opcional p/ número de WhatsApp COMPARTILHADO: o agente só responde
# mensagens que começam com esta palavra-chave (e ela é removida antes do agente).
# Deixe vazio quando a instância é dedicada só à clínica. Ex: /clinica
REQUIRE_KEYWORD=
